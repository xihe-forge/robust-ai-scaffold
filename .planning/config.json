{
  "mode": "interactive",
  "granularity": "standard",
  "responsive_breakpoints": [],
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": false,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },
  "gates": {
    "confirm_project": true,
    "confirm_phases": true,
    "confirm_roadmap": true,
    "confirm_breakdown": true,
    "confirm_plan": true,
    "issues_review": true,
    "confirm_transition": true
  },
  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },
  "discipline": {
    "tdd_default": true,
    "code_review_required": true,
    "verification_required": true
  },
  "review_gates": {
    "mrd_prd_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-mrd-prd.md",
      "tools": ["pm-skills", "superpowers"],
      "triggers": ["docs/mrd/", "docs/prd/", ".planning/REQUIREMENTS.md"]
    },
    "tech_design_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-tech-design.md",
      "tools": ["impeccable", "ui-ux-pro-max-skill", "open-lovable", "superpowers"],
      "triggers": ["docs/tech/", "docs/design/"]
    },
    "code_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-code.md",
      "tools": ["superpowers", "impeccable", "ui-ux-pro-max-skill"],
      "triggers": ["apps/", "packages/"]
    },
    "test_coverage_review": {
      "enabled": true,
      "blocking": true,
      "recipe": ".ai/recipes/review-test-coverage.md",
      "tools": ["superpowers", "pm-skills"],
      "triggers": ["test/", "*.test.*", "*.spec.*"],
      "require_full_prd_coverage": true
    },
    "marketing_review": {
      "enabled": true,
      "blocking": false,
      "recipe": ".ai/recipes/review-marketing.md",
      "tools": ["marketingskills", "pm-skills"],
      "triggers": ["docs/marketing/", "docs/mrd/"]
    }
  },
  "optional_modules": {
    "payment": {
      "enabled": false,
      "provider": "creem",
      "recipe": ".ai/recipes/payment-integration-guide.md",
      "payout_method": "wise"
    }
  },
  "user_profile": "standard",
  "review_strategy": {
    "mode": "auto",
    "custom_rounds": null,
    "zero_bug_threshold": 3
  },
  "final_review": {
    "enabled": true,
    "max_rounds": "auto",
    "parallel_reviewers": {
      "docs": ["opus", "codex"],
      "code": ["sonnet", "codex"]
    },
    "recipe": ".ai/recipes/review-final-iteration.md",
    "convergence": "zero_new_issues"
  },
  "review_tools": {
    "pm-skills": {
      "path": "opensource/pm-skills",
      "description": "65 PM skills — MRD/PRD/GTM validation"
    },
    "superpowers": {
      "path": "opensource/superpowers",
      "description": "TDD, code review, systematic debugging"
    },
    "impeccable": {
      "path": "opensource/impeccable",
      "description": "Frontend design anti-patterns, 17 audit commands"
    },
    "ui-ux-pro-max-skill": {
      "path": "opensource/ui-ux-pro-max-skill",
      "description": "Design system validation (50+ styles, 161 palettes)"
    },
    "open-lovable": {
      "path": "opensource/open-lovable",
      "description": "React component architecture reference"
    },
    "marketingskills": {
      "path": "opensource/marketingskills",
      "description": "34+ marketing skills — SEO, CRO, growth, positioning"
    }
  }
}
